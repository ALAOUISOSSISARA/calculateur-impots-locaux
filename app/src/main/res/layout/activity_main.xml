<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#F5F5F5">

    <!-- Titre -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estimation Prix Maison"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- Surface -->
    <EditText
        android:id="@+id/input_surface"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Surface (m²)"
        android:inputType="number"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="12dp"/>

    <!-- Nombre de pièces -->
    <EditText
        android:id="@+id/input_pieces"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de pièces"
        android:inputType="number"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="12dp"/>

    <!-- Checkbox piscine -->
    <CheckBox
        android:id="@+id/checkbox_piscine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Avec piscine (+50000€)"
        android:textSize="16sp"
        android:layout_marginBottom="20dp"/>

    <!-- Bouton calcul -->
    <Button
        android:id="@+id/button_calcul"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calculer le prix"
        android:textSize="16sp"
        android:padding="12dp"
        android:layout_marginBottom="20dp"/>

    <!-- Résultat -->
    <TextView
        android:id="@+id/result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Prix estimé : "
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="10dp"/>

</LinearLayout>